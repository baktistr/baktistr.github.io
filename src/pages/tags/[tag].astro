---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';

export async function getStaticPaths() {
  const blogPosts = await getCollection('blog');
  const docsPosts = await getCollection('docs');

  const allTags = new Set<string>();

  blogPosts
    .filter((post) => !post.data.draft)
    .forEach((post) => {
      post.data.tags.forEach((tag) => allTags.add(tag));
    });

  docsPosts
    .filter((post) => !post.data.draft)
    .forEach((post) => {
      post.data.tags.forEach((tag) => allTags.add(tag));
    });

  return Array.from(allTags).map((tag) => ({
    params: { tag },
    props: { tag },
  }));
}

interface Props {
  tag: string;
}

const { tag } = Astro.props;

const blogPosts = await getCollection('blog');
const docsPosts = await getCollection('docs');

const filteredBlogPosts = blogPosts
  .filter((post) => !post.data.draft && post.data.tags.includes(tag))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const filteredDocsPosts = docsPosts
  .filter((post) => !post.data.draft && post.data.tags.includes(tag))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const coTagCounts = new Map<string, number>();
for (const post of [...filteredBlogPosts, ...filteredDocsPosts]) {
  for (const t of post.data.tags) {
    if (t === tag) continue;
    coTagCounts.set(t, (coTagCounts.get(t) ?? 0) + 1);
  }
}
const coTags = [...coTagCounts.entries()].sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0])
);

const totalCount = filteredBlogPosts.length + filteredDocsPosts.length;
---

<BaseLayout title={`Tag: ${tag}`} description={`All posts tagged with ${tag}`}>
  <div class="max-w-4xl mx-auto">
    <header class="mb-8">
      <a
        href="/tags"
        class="inline-flex items-center gap-2 text-sm text-slate-400 light:text-slate-600 hover:text-cyan-400 light:hover:text-cyan-600 transition-colors mb-4"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        All Tags
      </a>
      <h1 class="text-3xl md:text-4xl font-bold text-slate-100 light:text-slate-900 mb-4">
        Tag: <span class="text-cyan-400 light:text-cyan-600">{tag}</span>
      </h1>
      <p class="text-lg text-slate-400 light:text-slate-600">
        <span id="results-count">{totalCount}</span> of {totalCount} post{totalCount !== 1 ? 's' : ''}
      </p>
    </header>

    {coTags.length > 0 && (
      <section class="mb-10 p-4 rounded-lg bg-slate-900/50 light:bg-white border border-slate-800 light:border-slate-200">
        <div class="flex items-center justify-between gap-3 mb-3 flex-wrap">
          <h2 class="text-sm font-semibold text-slate-300 light:text-slate-700">
            Refine with additional tags
          </h2>
          <button
            id="clear-filters"
            type="button"
            class="hidden text-xs text-slate-400 light:text-slate-600 hover:text-cyan-400 light:hover:text-cyan-600 transition-colors"
          >
            Clear filters
          </button>
        </div>
        <div id="refine-chips" class="flex flex-wrap gap-2">
          {coTags.map(([t, count]) => (
            <button
              type="button"
              class="refine-chip group inline-flex items-center gap-1.5 px-2.5 py-1 text-xs rounded-full border border-slate-700 light:border-slate-200 bg-slate-800/50 light:bg-slate-100 text-slate-300 light:text-slate-700 hover:border-cyan-400/50 light:hover:border-cyan-600/50 hover:text-cyan-400 light:hover:text-cyan-600 transition-colors data-[active=true]:bg-cyan-500/15 data-[active=true]:border-cyan-400 data-[active=true]:text-cyan-300 light:data-[active=true]:bg-cyan-500/10 light:data-[active=true]:border-cyan-600 light:data-[active=true]:text-cyan-700"
              data-tag={t}
              data-active="false"
            >
              <span>#{t}</span>
              <span class="text-slate-500 light:text-slate-500 group-data-[active=true]:text-cyan-500/80">{count}</span>
            </button>
          ))}
        </div>
      </section>
    )}

    {filteredBlogPosts.length > 0 && (
      <section class="mb-12" data-section="blog">
        <h2 class="text-xl font-bold text-slate-100 light:text-slate-900 mb-6">Blog Posts</h2>
        <div class="space-y-6">
          {filteredBlogPosts.map((post) => (
            <div class="filterable-item" data-tags={post.data.tags.join(' ')}>
              <PostCard post={post} />
            </div>
          ))}
        </div>
      </section>
    )}

    {filteredDocsPosts.length > 0 && (
      <section class="mb-12" data-section="docs">
        <h2 class="text-xl font-bold text-slate-100 light:text-slate-900 mb-6">Documentation</h2>
        <div class="space-y-4">
          {filteredDocsPosts.map((post) => (
            <div class="filterable-item" data-tags={post.data.tags.join(' ')}>
              <a
                href={`/docs/${post.slug}`}
                class="block p-4 rounded-lg bg-slate-900 light:bg-white border border-slate-800 light:border-slate-200 hover:border-cyan-400 light:hover:border-cyan-600 transition-colors"
              >
                <h3 class="font-semibold text-slate-100 light:text-slate-900 mb-1">
                  {post.data.title}
                </h3>
                <p class="text-sm text-slate-400 light:text-slate-600">
                  {post.data.description}
                </p>
              </a>
            </div>
          ))}
        </div>
      </section>
    )}

    {totalCount === 0 && (
      <div class="text-center py-12">
        <p class="text-slate-500 light:text-slate-400">No posts found with this tag.</p>
      </div>
    )}

    <div id="empty-filter-state" class="hidden text-center py-12">
      <p class="text-slate-500 light:text-slate-400">No posts match all selected filters.</p>
    </div>
  </div>
</BaseLayout>

<script>
  function initTagFilter() {
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.refine-chip'));
    const items = Array.from(document.querySelectorAll<HTMLElement>('.filterable-item'));
    const countEl = document.getElementById('results-count');
    const clearBtn = document.getElementById('clear-filters');
    const emptyState = document.getElementById('empty-filter-state');
    const sections = Array.from(document.querySelectorAll<HTMLElement>('[data-section]'));

    if (!chips.length || !items.length) return;

    const readSelected = (): Set<string> => {
      const params = new URLSearchParams(window.location.search);
      const raw = params.get('with');
      if (!raw) return new Set();
      return new Set(raw.split(',').map((s) => s.trim()).filter(Boolean));
    };

    const writeSelected = (selected: Set<string>) => {
      const url = new URL(window.location.href);
      if (selected.size === 0) {
        url.searchParams.delete('with');
      } else {
        url.searchParams.set('with', [...selected].join(','));
      }
      window.history.replaceState({}, '', url.toString());
    };

    const apply = (selected: Set<string>) => {
      for (const chip of chips) {
        const tagName = chip.dataset.tag ?? '';
        chip.dataset.active = selected.has(tagName) ? 'true' : 'false';
      }

      let visible = 0;
      for (const item of items) {
        const itemTags = new Set((item.dataset.tags ?? '').split(/\s+/).filter(Boolean));
        const match = [...selected].every((t) => itemTags.has(t));
        item.hidden = !match;
        if (match) visible += 1;
      }

      if (countEl) countEl.textContent = String(visible);

      for (const section of sections) {
        const anyVisible = section.querySelectorAll<HTMLElement>('.filterable-item:not([hidden])').length > 0;
        section.hidden = !anyVisible;
      }

      if (emptyState) emptyState.classList.toggle('hidden', visible !== 0 || items.length === 0);
      if (clearBtn) clearBtn.classList.toggle('hidden', selected.size === 0);
    };

    for (const chip of chips) {
      chip.addEventListener('click', () => {
        const tagName = chip.dataset.tag ?? '';
        const selected = readSelected();
        if (selected.has(tagName)) selected.delete(tagName);
        else selected.add(tagName);
        writeSelected(selected);
        apply(selected);
      });
    }

    clearBtn?.addEventListener('click', () => {
      writeSelected(new Set());
      apply(new Set());
    });

    apply(readSelected());
  }

  initTagFilter();
  document.addEventListener('astro:after-swap', initTagFilter);
</script>
